<script>
  let currentResults = null, currentBatchResults = null, aminoAcidInfo = null;

  async function fetchAminoAcidInfo() {
    const res = await fetch('/api/amino_acid_info');
    aminoAcidInfo = await res.json();
    renderAminoAcidGuide();
  }

  function renderAminoAcidGuide() {
    const container = document.getElementById('aminoAcidGuide');
    container.innerHTML = Object.entries(aminoAcidInfo).map(([aa, info]) => `
      <div class="col-3 mb-2 text-center">
        <div class="amino-acid-box" style="background-color: ${info.color}; cursor:pointer;" onclick="alert('${aa}: ${info.name} (${info.type})')">
          ${aa}
        </div>
        <small>${aa}</small>
      </div>
    `).join('');
  }

  async function initPerformanceRadar() {
    const res = await fetch('/api/model_info');
    const data = await res.json();
    const metrics = data.performance;
    document.getElementById('accuracyMetric').innerText = metrics.accuracy;
    document.getElementById('aucMetric').innerText = metrics.auc;
    document.getElementById('f1Metric').innerText = metrics.f1;
    document.getElementById('precisionMetric').innerText = metrics.precision;
    document.getElementById('recallMetric').innerText = metrics.recall;
    document.getElementById('mccMetric').innerText = metrics.mcc;

    const trace = {
      r: [metrics.accuracy, metrics.precision, metrics.recall, metrics.specificity || 0.8, metrics.f1, metrics.mcc],
      theta: ['Accuracy','Precision','Recall','Specificity','F1','MCC'],
      fill: 'toself', name: 'Performance', line: {color:'#27ae60', width:2}, fillcolor: 'rgba(39,174,96,0.2)'
    };
    Plotly.newPlot('performanceRadar', [trace], {polar: {radialaxis: {range: [0,1]}}, height: 280, margin: {t:30}});
  }

  async function predictSequence() {
    const seq = document.getElementById('sequenceInput').value.trim().toUpperCase();
    if (!seq) return alert('Enter a sequence');
    const btn = document.getElementById('predictBtn');
    const orig = btn.innerHTML;
    btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Predicting...';
    try {
      const res = await fetch('/predict', {method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({sequence: seq})});
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      currentResults = data;
      displayResults(data);
      document.getElementById('batchResultsSection').style.display = 'none';
      document.getElementById('resultsSection').style.display = 'block';
      document.getElementById('resultsSection').scrollIntoView({behavior: 'smooth'});
    } catch (err) { alert('Error: '+err.message); }
    finally { btn.disabled = false; btn.innerHTML = orig; }
  }

  function displayResults(data) {
    const isAnticancer = data.prediction === 'Anticancer Peptide';
    const conf = data.confidence;
    document.getElementById('predictionText').innerHTML = `<span class="${isAnticancer ? 'anticancer' : 'non-anticancer'}">${data.prediction}</span>`;
    document.getElementById('confidenceValue').innerText = conf+'%';
    document.getElementById('confidenceBar').style.width = conf+'%';
    document.getElementById('confidenceBar').className = `progress-bar ${isAnticancer ? 'bg-success' : 'bg-danger'}`;
    document.getElementById('seqLength').innerText = data.properties.length;
    document.getElementById('molWeight').innerText = data.properties.molecular_weight;
    document.getElementById('netCharge').innerText = data.properties.net_charge;
    document.getElementById('gravyScore').innerText = data.properties.gravy_score;

    const seqDiv = document.getElementById('sequenceDisplay');
    seqDiv.innerHTML = data.sequence.split('').map(aa => `<span class="amino-acid-box" style="background-color:${aminoAcidInfo[aa]?.color || '#999'}">${aa}</span>`).join('');

    Plotly.newPlot('attentionHeatmap', data.visualizations.attention_heatmap.data, {...data.visualizations.attention_heatmap.layout, height:350});
    Plotly.newPlot('featureImportance', data.visualizations.feature_importance.data, {...data.visualizations.feature_importance.layout, height:350});
    Plotly.newPlot('compositionPlot', data.visualizations.composition_plot.data, {...data.visualizations.composition_plot.layout, height:350});
  }

  async function batchPredict() {
    const text = document.getElementById('batchInput').value.trim();
    if (!text) return alert('Enter sequences');
    const btn = document.getElementById('batchPredictBtn');
    btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
    try {
      const res = await fetch('/batch_predict', {method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({sequences: text})});
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      currentBatchResults = data;
      const stats = data.statistics;
      document.getElementById('totalSequences').innerText = stats.total_sequences;
      document.getElementById('validSequences').innerText = stats.valid_sequences;
      document.getElementById('anticancerCount').innerText = stats.anticancer_count;
      document.getElementById('nonAnticancerCount').innerText = stats.non_anticancer_count;
      const tbody = document.getElementById('batchResultsBody');
      tbody.innerHTML = data.results.map(r => {
        if (!r.is_valid) return `<tr><td><span class="text-danger">${r.sequence.substring(0,30)}</span></td><td>-</td><td class="text-secondary">Invalid</td><td>-</td><td>${r.error}</td></tr>`;
        const isAnti = r.prediction === 'Anticancer';
        const conf = isAnti ? (r.probability*100).toFixed(1) : ((1-r.probability)*100).toFixed(1);
        return `<tr><td>${r.sequence}</td><td>${r.length}</td><td><span class="badge ${isAnti ? 'bg-success' : 'bg-danger'}">${r.prediction}</span></td><td>${r.probability}</td><td><div class="progress" style="height:20px"><div class="progress-bar ${isAnti ? 'bg-success' : 'bg-danger'}" style="width:${conf}%">${conf}%</div></div></td></tr>`;
      }).join('');
      document.getElementById('resultsSection').style.display = 'none';
      document.getElementById('batchResultsSection').style.display = 'block';
      document.getElementById('batchResultsSection').scrollIntoView({behavior: 'smooth'});
    } catch (err) { alert('Error: '+err.message); }
    finally { btn.disabled = false; btn.innerHTML = '<i class="fas fa-bolt"></i> Batch Predict'; }
  }

  function loadExample(type) {
    const ex = type === 'anticancer' ? 'GLFDIIKKIAESF' : 'SLDQINVTFLDLEYEMKKLEEAIKKLEESYIDLKEL';
    document.getElementById('sequenceInput').value = ex;
    document.getElementById('single-tab').click();
  }

  function clearSequence() { document.getElementById('sequenceInput').value = ''; document.getElementById('resultsSection').style.display = 'none'; }
  function clearBatch() { document.getElementById('batchInput').value = ''; document.getElementById('batchResultsSection').style.display = 'none'; }
  function downloadResults() { /* same as original */ }
  function downloadBatchResults() { /* same as original */ }
  function downloadBatchJSON() { /* same as original */ }
  function shareResults() { /* same as original */ }
  function toggleVisualization(id) { document.getElementById(id).classList.toggle('collapsed'); }

  document.addEventListener('DOMContentLoaded', () => {
    fetchAminoAcidInfo();
    initPerformanceRadar();
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', e => { e.preventDefault(); document.querySelector(anchor.getAttribute('href')).scrollIntoView({behavior:'smooth'}); });
    });
    ['attentionViz','featureImportanceViz','compositionViz'].forEach(id => document.getElementById(id)?.classList.add('collapsed'));
  });
</script>